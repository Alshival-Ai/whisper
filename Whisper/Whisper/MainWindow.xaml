                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="Birthdays" FontSize="14" FontWeight="SemiBold" Foreground="#FFE9ECF0" />
                                            <ToggleSwitch Grid.Column="1" OnContent="" OffContent="" />
                                        </Grid>
                                        <TextBlock Text="Don't see the calendar you want? See how to connect other calendars." FontSize="12" Foreground="#FF9FA7B1" />
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Grid>
                    </Grid>
                </ScrollViewer>

                <Grid x:Name="NotesPageView" Visibility="Collapsed">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Padding="24,12,24,0">
                        <Grid Width="980" HorizontalAlignment="Center">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <TextBox
                                Grid.Row="0"
                                x:Name="NoteTitleTextBox"
                                PlaceholderText="New note"
                                FontFamily="Georgia"
                                FontSize="24"
                                FontWeight="SemiBold"
                                Background="Transparent"
                                Foreground="#FFE6E8EA"
                                PlaceholderForeground="#AAE6E8EA"
                                BorderThickness="0"
                                HorizontalAlignment="Stretch"
                                Padding="0" />

                            <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="8" Margin="0,14,0,0">
                                <ComboBox
                                    x:Name="NoteDateComboBox"
                                    MinWidth="108"
                                    SelectedIndex="0"
                                    Background="#442E3238"
                                    BorderBrush="#553B414A"
                                    BorderThickness="1"
                                    CornerRadius="8"
                                    Foreground="#FFE0E4E8">
                                    <ComboBoxItem Content="Today" />
                                    <ComboBoxItem Content="Tomorrow" />
                                    <ComboBoxItem Content="Next week" />
                                </ComboBox>

                                <ComboBox
                                    x:Name="NoteAttendeesComboBox"
                                    MinWidth="120"
                                    SelectedIndex="0"
                                    Background="#442E3238"
                                    BorderBrush="#553B414A"
                                    BorderThickness="1"
                                    CornerRadius="8"
                                    Foreground="#FFE0E4E8">
                                    <ComboBoxItem Content="Me" />
                                    <ComboBoxItem Content="Team" />
                                    <ComboBoxItem Content="Abhi + me" />
                                </ComboBox>

                                <ComboBox
                                    x:Name="NoteFolderComboBox"
                                    MinWidth="160"
                                    SelectedIndex="0"
                                    Background="#442E3238"
                                    BorderBrush="#553B414A"
                                    BorderThickness="1"
                                    CornerRadius="8"
                                    Foreground="#FFE0E4E8">
                                    <ComboBoxItem Content="Add to folder" />
                                    <ComboBoxItem Content="Broward Health" />
                                    <ComboBoxItem Content="Customer calls" />
                                    <ComboBoxItem Content="Team meetings" />
                                </ComboBox>
                            </StackPanel>

                            <TextBox
                                Grid.Row="2"
                                x:Name="NoteBodyTextBox"
                                AcceptsReturn="True"
                                TextWrapping="Wrap"
                                MinHeight="420"
                                VerticalContentAlignment="Top"
                                PlaceholderText="Write notes..."
                                Background="Transparent"
                                BorderThickness="0"
                                Padding="0"
                                Margin="0,14,0,0"
                                HorizontalAlignment="Stretch"
                                Foreground="#FFD8DDE2"
                                PlaceholderForeground="#FF8A909A"
                                FontSize="18" />
                        </Grid>
                    </ScrollViewer>

                    <Grid Grid.Row="1" Width="980" HorizontalAlignment="Center" Margin="24,16,24,0" ColumnSpacing="10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel VerticalAlignment="Center" Spacing="6">
                            <Button
                                x:Name="CaptureToggleButton"
                                Padding="12,6"
                                CornerRadius="16"
                                Background="#DD373A3E"
                                BorderBrush="#663D4148"
                                BorderThickness="1"
                                Foreground="#FFE4E8EC">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <TextBlock x:Name="CaptureIndicatorText" Text="&#x25CF;" Foreground="#FF9BCB6D" FontSize="11" VerticalAlignment="Center" />
                                    <TextBlock x:Name="CaptureButtonText" Text="Start live transcript" FontSize="13" FontWeight="SemiBold" />
                                </StackPanel>
                            </Button>
                            <TextBlock
                                x:Name="CaptureStatusText"
                                Text="Ready to capture mic + system audio."
                                Foreground="#FF8F97A1"
                                FontSize="11"
                                Margin="2,0,0,0" />
