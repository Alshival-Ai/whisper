                        <Border
                            Grid.Column="1"
                            CornerRadius="20"
                            Background="#DD373A3E"
                            BorderBrush="#663D4148"
                            BorderThickness="1"
                            Padding="10,8">
                            <TextBox
                                x:Name="NoteAskTextBox"
                                PlaceholderText="Ask anything"
                                Background="Transparent"
                                BorderThickness="0"
                                Padding="0"
                                Foreground="#FFDCE0E4"
                                PlaceholderForeground="#FFA7ADB5"
                                FontSize="15" />
                        </Border>

                        <Button
                            x:Name="SuggestTopicsButton"
                            Grid.Column="2"
                            Padding="12,6"
                            CornerRadius="16"
                            Background="#FF303338"
                            BorderBrush="#66474C54"
                            BorderThickness="1"
                            Foreground="#FFE4E8EC"
                            Content="Suggest topics" />
                    </Grid>
                </Grid>
            </Grid>
        </Grid>
    </Grid>
</Window>
