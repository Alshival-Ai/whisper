                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="230" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Border
                            Grid.Column="0"
                            Background="#CC1A1B1D"
                            BorderBrush="#FF2E3136"
                            BorderThickness="0,0,1,0"
                            Padding="14,14,14,16">
                            <Grid RowSpacing="10">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>

                                <StackPanel Grid.Row="0" HorizontalAlignment="Center" Spacing="4" Margin="0,6,0,0">
                                    <Border Width="46" Height="46" CornerRadius="23" Background="#FFE5E7EA">
                                        <TextBlock Text="SC" Foreground="#FF1D2025" FontWeight="SemiBold" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                    </Border>
                                    <TextBlock Text="Samuel Cavazos" FontSize="28" FontFamily="Georgia" FontWeight="SemiBold" Foreground="#FFF0F3F6" HorizontalAlignment="Center" />
                                    <TextBlock Text="samuel@alshival.ai" FontSize="12" Foreground="#FFA7AEB8" HorizontalAlignment="Center" />
                                </StackPanel>

                                <Button
                                    Grid.Row="1"
                                    HorizontalAlignment="Center"
                                    Margin="0,4,0,0"
                                    Padding="10,4"
                                    CornerRadius="14"
                                    Background="#22303542"
                                    BorderBrush="#553D4450"
                                    BorderThickness="1"
                                    Foreground="#FFE3E8EE"
                                    Content="Edit profile" />

                                <TextBlock Grid.Row="2" Text="Preferences" Foreground="#FF9AA2AD" FontSize="12" Margin="0,8,0,0" />
                                <Button
                                    Grid.Row="3"
                                    Height="32"
                                    HorizontalAlignment="Stretch"
                                    HorizontalContentAlignment="Left"
                                    Padding="10,0"
                                    CornerRadius="8"
                                    Background="#FF2B2E33"
                                    BorderThickness="0"
                                    Foreground="#FFD9DDE2"
                                    Content="Calendar" />

                                <StackPanel Grid.Row="4" Spacing="7" Margin="2,0,0,0">
                                    <TextBlock Text="Notifications" Foreground="#FFAFB6C0" FontSize="12" />
                                    <TextBlock Text="Labs" Foreground="#FFAFB6C0" FontSize="12" />
                                </StackPanel>

                                <TextBlock Grid.Row="5" Text="Workspace" Foreground="#FF9AA2AD" FontSize="12" Margin="0,8,0,0" />
                                <StackPanel Grid.Row="6" Spacing="7" Margin="2,0,0,0">
                                    <TextBlock Text="General" Foreground="#FFAFB6C0" FontSize="12" />
                                    <TextBlock Text="Team" Foreground="#FFAFB6C0" FontSize="12" />
                                    <TextBlock Text="Billing" Foreground="#FFAFB6C0" FontSize="12" />
                                </StackPanel>

                                <TextBlock Grid.Row="7" Text="Support" Foreground="#FF9AA2AD" FontSize="12" Margin="0,8,0,0" />
                                <StackPanel Grid.Row="8" Spacing="7" Margin="2,0,0,0">
                                    <TextBlock Text="Help Center" Foreground="#FFAFB6C0" FontSize="12" />
                                    <TextBlock Text="Send feedback" Foreground="#FFAFB6C0" FontSize="12" />
                                </StackPanel>
                            </Grid>
                        </Border>

                        <Grid Grid.Column="1">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <StackPanel Orientation="Horizontal" Spacing="8" Margin="16,10,0,0">
                                <Button
                                    x:Name="SettingsBackButton"
                                    Width="28"
                                    Height="24"
                                    Padding="0"
                                    Background="#332F343A"
                                    BorderBrush="#553E444C"
                                    BorderThickness="1"
                                    CornerRadius="12">
                                    <FontIcon Glyph="&#xE72B;" FontSize="10" Foreground="#FFD0D5DB" />
                                </Button>
                                <Button
                                    Width="28"
                                    Height="24"
                                    Padding="0"
                                    IsEnabled="False"
                                    Background="#222B2F35"
                                    BorderBrush="#443E444C"
                                    BorderThickness="1"
                                    CornerRadius="12">
                                    <FontIcon Glyph="&#xE72A;" FontSize="10" Foreground="#889CA3AE" />
                                </Button>
                            </StackPanel>

                            <StackPanel Grid.Row="1" MaxWidth="900" Margin="22,14,24,24" Spacing="18">
                                <TextBlock Text="Calendar" FontFamily="Georgia" FontSize="44" FontWeight="SemiBold" Foreground="#FFF2F4F6" />

                                <TextBlock Text="Display" FontSize="14" Foreground="#FF99A2AD" />
                                <Border
                                    CornerRadius="14"
                                    BorderThickness="1"
                                    BorderBrush="#66434952"
                                    Background="#A43A3D42"
                                    Padding="14,10">
                                    <Grid ColumnSpacing="12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel>
                                            <TextBlock Text="Show events with no participants" FontSize="14" FontWeight="SemiBold" Foreground="#FFE9ECF0" />
                                            <TextBlock Text="'Coming up' section will include events without participants or a video link." FontSize="12" Foreground="#FF9FA7B1" />
                                        </StackPanel>
                                        <ToggleSwitch Grid.Column="1" IsOn="True" OnContent="" OffContent="" />
                                    </Grid>
                                </Border>

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Visible calendars" FontSize="14" Foreground="#FF99A2AD" />
                                    <TextBlock Grid.Column="1" Text="Reset" FontSize="14" Foreground="#FF97BF45" />
                                </Grid>

                                <Border
                                    CornerRadius="14"
                                    BorderThickness="1"
                                    BorderBrush="#66434952"
                                    Background="#A43A3D42"
                                    Padding="14,10">
                                    <StackPanel Spacing="10">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="Calendar" FontSize="14" FontWeight="SemiBold" Foreground="#FFE9ECF0" />
                                            <ToggleSwitch Grid.Column="1" IsOn="True" OnContent="" OffContent="" />
                                        </Grid>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="Prosource" FontSize="14" FontWeight="SemiBold" Foreground="#FFE9ECF0" />
